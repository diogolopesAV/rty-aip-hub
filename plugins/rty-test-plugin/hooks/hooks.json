{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[rty-test-plugin] Plugin active — skills, hooks, and MCP loaded.'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[rty-test-plugin] Bash tool called: $CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      }
    ]
  }
}
