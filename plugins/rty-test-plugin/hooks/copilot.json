{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "echo '[rty-test-plugin] Session started — Copilot hooks active.'",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "matcher": "bash",
        "command": "echo '[rty-test-plugin] PreToolUse: bash intercepted.'",
        "timeoutSec": 10
      }
    ]
  }
}
